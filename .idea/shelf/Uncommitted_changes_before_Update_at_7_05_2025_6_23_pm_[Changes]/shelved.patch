rintln(\"Worker clicked - \" +\r\n                        \"Player ID: \" + worker.getPlayerId() + \", \" +\r\n                        \"Worker ID: \" + worker.getWorkerId() + \", \" +\r\n                        \"Position: (\" + worker.getRow() + \", \" + worker.getCol() + \")\");\r\n                return;\r\n            }\r\n        }\r\n\r\n        System.out.println(\"No worker at position (\" + row + \", \" + col + \")\");\r\n    }\r\n}\r\n
